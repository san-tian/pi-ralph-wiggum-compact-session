{
  "name": "pi-ralph-wiggum-compact-session",
  "version": "0.2.1",
  "description": "Ralph Wiggum for Pi, modified to compact and continue inside the same session.",
  "license": "MIT",
  "author": "Thomas Mustier",
  "keywords": [
    "pi-package",
    "ralph-loop",
    "compaction",
    "session"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit --module preserve --moduleResolution bundler --target es2022 --skipLibCheck index.ts"
  },
  "files": [
    "CHANGELOG.md",
    "LICENSE",
    "README.md",
    "skills",
    "index.ts"
  ],
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": "*",
    "@sinclair/typebox": "*"
  },
  "dependencies": {
    "@san-tian/pi-project-paths": "git+https://github.com/san-tian/pi-project-paths.git#v0.1.0"
  },
  "pi": {
    "extensions": [
      "index.ts"
    ],
    "skills": [
      "./skills"
    ],
    "image": "https://github.com/user-attachments/assets/68cdab11-76c6-4aed-9ea1-558cbb267ea6"
  },
  "devDependencies": {
    "@mariozechner/pi-coding-agent": "^0.64.0",
    "@sinclair/typebox": "^0.34.49",
    "@types/node": "^25.5.0",
    "typescript": "^6.0.2"
  }
}
